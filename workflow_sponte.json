    "Extrair AlunoID": {
      "main": [
        [ { "node": "Aluno Encontrado?", "type": "main", "index": 0 } ]
      ]
    },
    "Aluno Encontrado?": {
      "main": [
        [ { "node": "Buscar Boletos V3", "type": "main", "index": 0 } ],
        [ { "node": "Aluno Não Encontrado", "type": "main", "index": 0 } ]
      ]
    },
    "Buscar Boletos V3": {
      "main": [
        [ { "node": "Processar Boletos", "type": "main", "index": 0 } ]
      ]
    },
    "Processar Boletos": {
      "main": [
        [ { "node": "Form Response Final", "type": "main", "index": 0 } ]
      ]
    }
  }
